<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                              http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Bankomunal - Modulo Servlets y JSP</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== SERVLETS ==================== -->

    <servlet>
        <servlet-name>RegistroServlet</servlet-name>
        <servlet-class>com.bankomunal.servlets.RegistroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.bankomunal.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.bankomunal.servlets.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MetasAhorroServlet</servlet-name>
        <servlet-class>com.bankomunal.servlets.MetasAhorroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MetasAhorroServlet</servlet-name>
        <url-pattern>/metas</url-pattern>
    </servlet-mapping>

    <!-- ==================== FILTRO DE AUTENTICACION ==================== -->

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.bankomunal.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/metas</url-pattern>
    </filter-mapping>

    <!-- ==================== SESION ==================== -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ==================== PAGINAS DE ERROR ==================== -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

</web-app>
